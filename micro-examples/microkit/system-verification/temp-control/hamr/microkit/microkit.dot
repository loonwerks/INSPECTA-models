digraph microkit {
  compound=true;

  // Do not edit this file as it will be overwritten if HAMR codegen is rerun

  // protection domains
  graph [style=rounded]
  subgraph cluster_tsp_tst_MON {
    label = "tsp_tst_MON";
    tsp_tst_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_tsp_tst {
      label = "tsp_tst";
      tsp_tst_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_tsp_tst_currentTemp_queue_1 [label=currentTemp_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_tcp_tct_MON {
    label = "tcp_tct_MON";
    tcp_tct_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_tcp_tct {
      label = "tcp_tct";
      tcp_tct_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_tcp_tct_currentTemp_queue_1 [label=currentTemp_queue_1];
      pd_tcp_tct_fanCmd_queue_1 [label=fanCmd_queue_1];
      pd_tcp_tct_setPoint_queue_1 [label=setPoint_queue_1];
      pd_tcp_tct_fanAck_queue_1 [label=fanAck_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_fp_ft_MON {
    label = "fp_ft_MON";
    fp_ft_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_fp_ft {
      label = "fp_ft";
      fp_ft_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_fp_ft_fanCmd_queue_1 [label=fanCmd_queue_1];
      pd_fp_ft_fanAck_queue_1 [label=fanAck_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_pacer {
    label = "pacer";
    pacer_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

  }

  // memory regions
  TempControlSystem_Instance_tsp_tst_currentTemp_1_Memory_Region;

  TempControlSystem_Instance_tcp_tct_fanCmd_1_Memory_Region;

  TempControlSystem_Instance_tcp_tct_setPoint_1_Memory_Region;

  TempControlSystem_Instance_fp_ft_fanAck_1_Memory_Region;

  // channels
  pacer_INVIS -> tsp_tst_MON_INVIS [lhead=cluster_tsp_tst_MON, minlen=2, dir=both];
  tsp_tst_MON_INVIS -> tsp_tst_INVIS [lhead=cluster_tsp_tst, minlen=2, dir=both];
  pacer_INVIS -> tcp_tct_MON_INVIS [lhead=cluster_tcp_tct_MON, minlen=2, dir=both];
  tcp_tct_MON_INVIS -> tcp_tct_INVIS [lhead=cluster_tcp_tct, minlen=2, dir=both];
  pacer_INVIS -> fp_ft_MON_INVIS [lhead=cluster_fp_ft_MON, minlen=2, dir=both];
  fp_ft_MON_INVIS -> fp_ft_INVIS [lhead=cluster_fp_ft, minlen=2, dir=both];

  // shared memory mappings
  pd_tsp_tst_currentTemp_queue_1 -> TempControlSystem_Instance_tsp_tst_currentTemp_1_Memory_Region [dir=both, style=dashed];
  pd_tcp_tct_currentTemp_queue_1 -> TempControlSystem_Instance_tsp_tst_currentTemp_1_Memory_Region [dir=back, style=dashed];
  pd_tcp_tct_fanCmd_queue_1 -> TempControlSystem_Instance_tcp_tct_fanCmd_1_Memory_Region [dir=both, style=dashed];
  pd_tcp_tct_setPoint_queue_1 -> TempControlSystem_Instance_tcp_tct_setPoint_1_Memory_Region [dir=back, style=dashed];
  pd_tcp_tct_fanAck_queue_1 -> TempControlSystem_Instance_fp_ft_fanAck_1_Memory_Region [dir=back, style=dashed];
  pd_fp_ft_fanCmd_queue_1 -> TempControlSystem_Instance_tcp_tct_fanCmd_1_Memory_Region [dir=back, style=dashed];
  pd_fp_ft_fanAck_queue_1 -> TempControlSystem_Instance_fp_ft_fanAck_1_Memory_Region [dir=both, style=dashed];
}