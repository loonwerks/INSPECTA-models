# Do not edit this file as it will be overwritten if HAMR codegen is rerun

MICROKIT_TOOL ?= $(MICROKIT_SDK)/bin/microkit

CFLAGS := -mcpu=$(CPU) \
	-mstrict-align \
	-ffreestanding \
	-nostdlib \
	-g3 \
	-O3 \
	-Wall -Wno-unused-function -Werror -Wno-unused-command-line-argument \
	-I$(MICROKIT_BOARD_DIR)/include \
	-target $(TARGET)

LDFLAGS := -L$(MICROKIT_BOARD_DIR)/lib
LIBS := --start-group -lmicrokit -Tmicrokit.ld --end-group

MSD ?= microkit.system

IMAGES := producer_p_p_producer.elf producer_p_p_producer_MON.elf consumer_p_p_consumer.elf consumer_p_p_consumer_MON.elf pacer.elf
IMAGE_FILE = loader.img
REPORT_FILE = report.txt

UTIL_OBJS = printf.o util.o

TYPES_DIR = $(TOP_DIR)/types
TYPE_OBJS := $(TOP_DIR)/build/sb_queue_vest_1prod_1cons_ArrayOfByte_1.o

# exporting TOP_TYPES_INCLUDE in case other makefiles need it
export TOP_TYPES_INCLUDE = -I$(TYPES_DIR)/include

TOP_INCLUDE = $(TOP_TYPES_INCLUDE) -I$(TOP_DIR)/util/include

all: $(IMAGE_FILE)
	CHECK_FLAGS_BOARD_MD5:=.board_cflags-$(shell echo -- ${CFLAGS} ${MICROKIT_BOARD} ${MICROKIT_CONFIG}| shasum | sed 's/ *-//')

${CHECK_FLAGS_BOARD_MD5}:
	-rm -f .board_cflags-*
	touch $@

%.o: ${TOP_DIR}/util/src/%.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ -I$(TOP_DIR)/util/include

$(TOP_DIR)/build/sb_queue_vest_1prod_1cons_ArrayOfByte_1.o: $(TOP_DIR)/types/src/sb_queue_vest_1prod_1cons_ArrayOfByte_1.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE)


# monitor
producer_p_p_producer_MON.o: $(TOP_DIR)/components/producer_p_p_producer/src/producer_p_p_producer_MON.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/producer_p_p_producer/include

# user code
producer_p_p_producer_rust:
	make -C ${CRATES_DIR}/producer_p_p_producer $(RUST_MAKE_TARGET)

producer_p_p_producer.o: $(TOP_DIR)/components/producer_p_p_producer/src/producer_p_p_producer.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/producer_p_p_producer/include

# monitor
consumer_p_p_consumer_MON.o: $(TOP_DIR)/components/consumer_p_p_consumer/src/consumer_p_p_consumer_MON.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/consumer_p_p_consumer/include

# user code
consumer_p_p_consumer_rust:
	make -C ${CRATES_DIR}/consumer_p_p_consumer $(RUST_MAKE_TARGET)

consumer_p_p_consumer.o: $(TOP_DIR)/components/consumer_p_p_consumer/src/consumer_p_p_consumer.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/consumer_p_p_consumer/include

pacer.o: $(TOP_DIR)/components/pacer/src/pacer.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ -I$(TOP_INCLUDE)

# Copy the custom linker script into the build directory before linking any
# ELFs. The linker resolves -Tmicrokit.ld by searching the current directory
# first, so this override takes precedence over the SDK's default copy.
$(TOP_BUILD_DIR)/microkit.ld: $(TOP_DIR)/microkit.ld
	cp $< $@

producer_p_p_producer_MON.elf: producer_p_p_producer_MON.o | $(TOP_BUILD_DIR)/microkit.ld
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

producer_p_p_producer.elf: $(UTIL_OBJS) $(TYPE_OBJS) producer_p_p_producer_rust producer_p_p_producer.o | $(TOP_BUILD_DIR)/microkit.ld
	$(LD) $(LDFLAGS) -L ${CRATES_DIR}/producer_p_p_producer/target/aarch64-unknown-none/release $(filter %.o, $^) $(LIBS) -lproducer_p_p_producer -o $@

consumer_p_p_consumer_MON.elf: consumer_p_p_consumer_MON.o | $(TOP_BUILD_DIR)/microkit.ld
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

consumer_p_p_consumer.elf: $(UTIL_OBJS) $(TYPE_OBJS) consumer_p_p_consumer_rust consumer_p_p_consumer.o | $(TOP_BUILD_DIR)/microkit.ld
	$(LD) $(LDFLAGS) -L ${CRATES_DIR}/consumer_p_p_consumer/target/aarch64-unknown-none/release $(filter %.o, $^) $(LIBS) -lconsumer_p_p_consumer -o $@

pacer.elf: $(UTIL_OBJS) $(TYPE_OBJS) pacer.o | $(TOP_BUILD_DIR)/microkit.ld
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

$(IMAGE_FILE): $(IMAGES) $(TOP_DIR)/$(MSD)
	xmllint --xinclude $(TOP_DIR)/$(MSD) | awk 'FNR==1{print; print "<!--"; print "  DO NOT EDIT: This file is generated by merging"; print "    $(TOP_DIR)/$(MSD)"; print "  and its xi:included files."; print "  Modify the source files and run make instead."; print "-->"; next}1' > $(TOP_BUILD_DIR)/$(MSD).merged
	$(MICROKIT_TOOL) $(TOP_BUILD_DIR)/$(MSD).merged --search-path $(TOP_BUILD_DIR) --board $(MICROKIT_BOARD) --config $(MICROKIT_CONFIG) -o $(IMAGE_FILE) -r $(REPORT_FILE)


qemu:
	$(QEMU) -machine virt,virtualization=on \
			-cpu cortex-a53 \
			-serial mon:stdio \
			-device loader,file=$(IMAGE_FILE),addr=0x70000000,cpu-num=0 \
			-m size=2G \
			-nographic

clean::
	rm -f *.o

test:: 
	make -C ${CRATES_DIR}/producer_p_p_producer test
	make -C ${CRATES_DIR}/consumer_p_p_consumer test

clean:: 
	make -C ${CRATES_DIR}/producer_p_p_producer clean
	make -C ${CRATES_DIR}/consumer_p_p_consumer clean

verus: 
	make -C ${CRATES_DIR}/producer_p_p_producer verus
	make -C ${CRATES_DIR}/consumer_p_p_consumer verus
